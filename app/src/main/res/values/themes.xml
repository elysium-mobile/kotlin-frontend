<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Manifest-level theme used during the cold-start window before Compose takes over.

        Inherits Theme.AppCompat.DayNight.NoActionBar so AppCompat's locale back-port and
        per-app language settings continue to work on API 29-32. The SoftWork brand uses
        a single light visual treatment regardless of system dark mode, so the window
        background and the legacy colorBackground attribute are pinned to white. This
        prevents the platform from painting the dark-theme black behind the Compose tree
        on the very first frame, which would otherwise remain visible through the
        transparent system bars (enabled by edge-to-edge) until the Compose Surface
        finishes its initial measure-and-draw pass.
    -->
    <style name="Theme.SoftWork" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:colorBackground">@android:color/white</item>
    </style>
</resources>
